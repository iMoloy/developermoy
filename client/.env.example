# ── Client Environment Variables ──────────────────────────────
# Copy to .env.local and populate values.

# The public-facing URL of the Express API (e.g., https://api.developermoy.com)
NEXT_PUBLIC_API_URL=http://localhost:5000/api

# The public-facing URL of this Next.js app (used for OG images, canonical URLs, etc.)
NEXT_PUBLIC_APP_URL=http://localhost:3000
